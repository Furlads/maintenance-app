generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://neondb_owner:npg_HFRSJY2COVN7@ep-empty-shadow-abi6r1x8-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
}

model Company {
  id        Int             @id @default(autoincrement())
  name      String
  createdAt DateTime        @default(now())
  workers   WorkerCompany[]
}

model Worker {
  id          Int             @id @default(autoincrement())
  phone       String?
  email       String?
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  accessLevel String
  firstName   String
  jobTitle    String
  lastName    String
  jobs        Job[]
  notes       JobNote[]
  companies   WorkerCompany[]
}

model WorkerCompany {
  id        Int     @id @default(autoincrement())
  workerId  Int
  companyId Int
  company   Company @relation(fields: [companyId], references: [id])
  worker    Worker  @relation(fields: [workerId], references: [id])
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  email     String?
  address   String?
  postcode  String?
  notes     String?
  createdAt DateTime @default(now())
  jobs      Job[]
}

model Job {
  id               Int       @id @default(autoincrement())
  title            String
  customerId       Int
  address          String
  notes            String?
  assignedWorkerId Int?
  visitDate        DateTime?
  startTime        String?
  durationMinutes  Int?
  status           String    @default("unscheduled")
  createdAt        DateTime  @default(now())
  worker           Worker?   @relation(fields: [assignedWorkerId], references: [id])
  customer         Customer  @relation(fields: [customerId], references: [id])
  jobNotes         JobNote[]
}

model JobNote {
  id                Int      @id @default(autoincrement())
  jobId             Int
  note              String
  createdAt         DateTime @default(now())
  createdByWorkerId Int?
  worker            Worker?  @relation(fields: [createdByWorkerId], references: [id])
  job               Job      @relation(fields: [jobId], references: [id])
}
