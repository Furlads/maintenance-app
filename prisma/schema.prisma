// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Worker {
  id                 String   @id @default(cuid())
  name               String
  phone              String
  role               String?
  photoUrl           String?
  archivedAt          DateTime?

  // ✅ AUTH (TEST-SAFE)
  // Optional so existing DB rows don't crash the API.
  passwordHash       String?
  mustChangePassword Boolean  @default(true)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  jobs               Job[]
}

model Job {
  id           String   @id @default(cuid())
  title        String
  address      String
  postcode     String?
  notes        String?

  status       String   @default("unscheduled")
  visitDate    DateTime?
  startTime    String?
  fixed        Boolean  @default(false)

  // store canonical workerKey: lowercase full name
  assignedTo   String?

  durationMins Int      @default(60)
  overrunMins  Int      @default(0)
  arrivedAt    DateTime?
  finishedAt   DateTime?

  // optional recurrence (future)
  recurrenceActive        Boolean @default(false)
  recurrenceEveryWeeks    Int?
  recurrenceDurationMins  Int?
  recurrencePreferredDOW  Int?
  recurrencePreferredTime String?

  workerId     String?
  worker       Worker?  @relation(fields: [workerId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}