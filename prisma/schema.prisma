generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        Int             @id @default(autoincrement())
  name      String
  createdAt DateTime        @default(now())

  workers   WorkerCompany[]
}

model Worker {
  id             Int             @id @default(autoincrement())
  firstName      String
  lastName       String
  jobTitle       String
  accessLevel    String
  phone          String?
  email          String?
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())

  companies      WorkerCompany[]
  notes          JobNote[]
  assignedJobs   JobAssignment[]
  uploadedPhotos JobPhoto[]
}

model WorkerCompany {
  id        Int     @id @default(autoincrement())

  workerId  Int
  companyId Int

  worker    Worker  @relation(fields: [workerId], references: [id])
  company   Company @relation(fields: [companyId], references: [id])
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  email     String?
  address   String?
  postcode  String?
  notes     String?
  createdAt DateTime @default(now())

  jobs      Job[]
}

model Job {
  id              Int             @id @default(autoincrement())
  title           String
  customerId      Int
  address         String
  notes           String?
  jobType         String          @default("Quote")
  visitDate       DateTime?
  startTime       String?
  durationMinutes Int?
  overrunMins     Int             @default(0)

  arrivedAt       DateTime?
  finishedAt      DateTime?

  pausedAt        DateTime?
  pausedMinutes   Int             @default(0)

  status          String          @default("unscheduled")
  createdAt       DateTime        @default(now())

  customer        Customer        @relation(fields: [customerId], references: [id])
  jobNotes        JobNote[]
  assignments     JobAssignment[]
  photos          JobPhoto[]
  chasMessages    ChasMessage[]
}

model JobAssignment {
  id        Int      @id @default(autoincrement())
  jobId     Int
  workerId  Int
  createdAt DateTime @default(now())

  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([jobId, workerId])
}

model JobNote {
  id                Int      @id @default(autoincrement())
  jobId             Int
  note              String
  createdAt         DateTime @default(now())
  createdByWorkerId Int?

  job               Job      @relation(fields: [jobId], references: [id])
  worker            Worker?  @relation(fields: [createdByWorkerId], references: [id])
}

model JobPhoto {
  id                 Int      @id @default(autoincrement())
  jobId              Int
  uploadedByWorkerId Int?
  label              String?
  imageUrl           String
  createdAt          DateTime @default(now())

  job                Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  uploadedByWorker   Worker?  @relation(fields: [uploadedByWorkerId], references: [id])
}

model ChasMessage {
  id                    Int      @id @default(autoincrement())
  company               String
  worker                String
  jobId                 Int?
  question              String
  answer                String
  imageDataUrl          String?
  responseId            String?
  createdAt             DateTime @default(now())

  intent                String?
  confidence            Float?
  escalateTo            String?
  safetyFlag            Boolean  @default(false)

  customerName          String?
  customerPhone         String?
  customerEmail         String?
  customerAddress       String?
  customerPostcode      String?

  workSummary           String?
  estimatedHours        Float?
  roughPriceText        String?
  enquirySummary        String?
  enquiryReadyForKelly  Boolean  @default(false)

  job                   Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([company, worker, createdAt])
  @@index([jobId])
  @@index([enquiryReadyForKelly, createdAt])
}