generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())

  workers WorkerCompany[]
}

model Worker {
  id          Int      @id @default(autoincrement())
  firstName   String
  lastName    String
  jobTitle    String
  accessLevel String
  phone       String?
  email       String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  pinHash     String?

  passwordHash        String?
  mustChangePassword  Boolean  @default(false)
  failedLoginAttempts Int      @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?

  companies            WorkerCompany[]
  notes                JobNote[]
  assignedJobs         JobAssignment[]
  uploadedPhotos       JobPhoto[]
  webauthnCredentials  WebAuthnCredential[]
  timeOffRequests      TimeOffRequest[]
  availabilityBlocks   WorkerAvailabilityBlock[]
}

model WebAuthnCredential {
  id         String @id
  workerId   Int
  publicKey  String
  counter    Int
  deviceType String
  backedUp   Boolean
  transports String?

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId])
}

model WorkerCompany {
  id Int @id @default(autoincrement())

  workerId  Int
  companyId Int

  worker  Worker  @relation(fields: [workerId], references: [id])
  company Company @relation(fields: [companyId], references: [id])
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  email     String?
  address   String?
  postcode  String?
  notes     String?
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())

  jobs          Job[]
  inboxMessages InboxMessage[]
}

model Job {
  id               Int       @id @default(autoincrement())
  title            String
  customerId       Int
  address          String
  notes            String?
  jobType          String    @default("Quote")
  visitDate        DateTime?
  startTime        String?
  durationMinutes  Int?
  overrunMins      Int       @default(0)

  arrivedAt        DateTime?
  finishedAt       DateTime?

  pausedAt         DateTime?
  pausedMinutes    Int       @default(0)

  status           String    @default("unscheduled")
  paymentStatus    String?
  paymentNotes     String?
  createdAt        DateTime  @default(now())

  visitPattern              String?
  isRegularMaintenance      Boolean  @default(false)
  maintenanceFrequency      String?
  maintenanceFrequencyUnit  String?
  maintenanceFrequencyWeeks Int?
  timePreferenceMode        String?
  preferredDay              String?
  preferredTimeBand         String?

  customer      Customer        @relation(fields: [customerId], references: [id])
  jobNotes      JobNote[]
  assignments   JobAssignment[]
  photos        JobPhoto[]
  chasMessages  ChasMessage[]
  inboxMessages InboxMessage[]
}

model JobAssignment {
  id        Int      @id @default(autoincrement())
  jobId     Int
  workerId  Int
  createdAt DateTime @default(now())

  job    Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([jobId, workerId])
}

model JobNote {
  id                Int      @id @default(autoincrement())
  jobId             Int
  note              String
  createdAt         DateTime @default(now())
  createdByWorkerId Int?

  job    Job     @relation(fields: [jobId], references: [id])
  worker Worker? @relation(fields: [createdByWorkerId], references: [id])
}

model JobPhoto {
  id                 Int      @id @default(autoincrement())
  jobId              Int
  uploadedByWorkerId Int?
  label              String?
  imageUrl           String
  createdAt          DateTime @default(now())

  job              Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  uploadedByWorker Worker? @relation(fields: [uploadedByWorkerId], references: [id])
}

model ChasMessage {
  id             Int      @id @default(autoincrement())
  company        String
  worker         String
  sessionId      String?
  jobId          Int?
  question       String
  answer         String
  imageDataUrl   String?
  responseId     String?
  conversationId String?
  createdAt      DateTime @default(now())

  intent     String?
  confidence Float?
  escalateTo String?
  safetyFlag Boolean @default(false)

  customerName     String?
  customerPhone    String?
  customerEmail    String?
  customerAddress  String?
  customerPostcode String?

  workSummary          String?
  estimatedHours       Float?
  roughPriceText       String?
  enquirySummary       String?
  enquiryReadyForKelly Boolean @default(false)

  job Job? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([company, worker, createdAt])
  @@index([company, worker, sessionId, createdAt])
  @@index([jobId])
  @@index([enquiryReadyForKelly, createdAt])
  @@index([conversationId])
}

model Conversation {
  id          String   @id @default(cuid())
  source      String
  contactName String?
  contactRef  String?
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())

  messages InboxMessage[]

  @@index([archived])
}

model InboxMessage {
  id Int @id @default(autoincrement())

  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id])

  source String

  senderName  String?
  senderEmail String?
  senderPhone String?
  subject     String?
  preview     String?
  body        String?

  externalMessageId String?

  assignedTo String?
  status     String  @default("unread")

  customerId Int?
  jobId      Int?

  createdAt DateTime @default(now())

  customer Customer? @relation(fields: [customerId], references: [id])
  job      Job?      @relation(fields: [jobId], references: [id])

  @@index([conversationId])
  @@index([source, createdAt])
  @@index([status, createdAt])
  @@index([customerId])
  @@index([jobId])
  @@unique([source, externalMessageId])
}

model InboxConnection {
  id        String   @id @default(cuid())
  service   String   @unique
  account   String?
  lastSync  DateTime?

  accessToken       String?
  refreshToken      String?
  tokenExpiresAt    DateTime?
  externalAccountId String?
  syncError         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TimeOffRequest {
  id               Int      @id @default(autoincrement())
  workerId         Int
  requestType      String
  status           String   @default("pending")
  startDate        DateTime
  endDate          DateTime
  startTime        String?
  endTime          String?
  isFullDay        Boolean  @default(true)
  reason           String?
  requestedByName  String?
  reviewedByName   String?
  reviewNotes      String?
  reviewedAt       DateTime?
  cancelledAt      DateTime?
  cancellationNote String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  worker            Worker                  @relation(fields: [workerId], references: [id], onDelete: Cascade)
  availabilityBlock WorkerAvailabilityBlock?

  @@index([workerId, status, startDate])
  @@index([status, createdAt])
  @@index([startDate, endDate])
}

model WorkerAvailabilityBlock {
  id            Int      @id @default(autoincrement())
  workerId      Int
  requestId     Int?     @unique
  source        String   @default("time_off_request")
  title         String
  startDate     DateTime
  endDate       DateTime
  startTime     String?
  endTime       String?
  isFullDay     Boolean  @default(true)
  notes         String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  worker  Worker          @relation(fields: [workerId], references: [id], onDelete: Cascade)
  request TimeOffRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  @@index([workerId, active, startDate, endDate])
  @@index([startDate, endDate])
}