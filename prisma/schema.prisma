generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        Int             @id @default(autoincrement())
  name      String
  createdAt DateTime        @default(now())
  workers   WorkerCompany[]
}

model Worker {
  id                  Int                       @id @default(autoincrement())
  phone               String?
  email               String?
  active              Boolean                   @default(true)
  createdAt           DateTime                  @default(now())
  accessLevel         String
  firstName           String
  jobTitle            String
  lastName            String
  pinHash             String?
  failedLoginAttempts Int                       @default(0)
  lastLoginAt         DateTime?
  lockedUntil         DateTime?
  passwordHash        String?
  mustChangePassword  Boolean                   @default(false)
  assignedJobs        JobAssignment[]
  notes               JobNote[]
  uploadedPhotos      JobPhoto[]
  timeOffRequests     TimeOffRequest[]
  webauthnCredentials WebAuthnCredential[]
  availabilityBlocks  WorkerAvailabilityBlock[]
  companies           WorkerCompany[]
  chasMessages        ChasMessage[]
  jobAuditLogs        JobAuditLog[]

  @@index([active, accessLevel])
  @@index([lastName, firstName])
  @@index([email])
}

model WebAuthnCredential {
  id         String  @id
  workerId   Int
  publicKey  String
  counter    Int
  deviceType String
  backedUp   Boolean
  transports String?
  worker     Worker  @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId])
}

model WorkerCompany {
  id        Int     @id @default(autoincrement())
  workerId  Int
  companyId Int
  company   Company @relation(fields: [companyId], references: [id])
  worker    Worker  @relation(fields: [workerId], references: [id])

  @@unique([workerId, companyId])
  @@index([companyId])
}

model Customer {
  id            Int            @id @default(autoincrement())
  name          String
  phone         String?
  email         String?
  address       String?
  postcode      String?
  notes         String?
  createdAt     DateTime       @default(now())
  archived      Boolean        @default(false)
  inboxMessages InboxMessage[]
  jobs          Job[]

  @@index([archived, createdAt])
  @@index([name])
  @@index([postcode])
}

model Job {
  id                        Int             @id @default(autoincrement())
  title                     String
  customerId                Int
  address                   String
  notes                     String?
  visitDate                 DateTime?
  startTime                 String?
  durationMinutes           Int?
  status                    String          @default("unscheduled")
  createdAt                 DateTime        @default(now())
  jobType                   String          @default("Quote")
  arrivedAt                 DateTime?
  finishedAt                DateTime?
  overrunMins               Int             @default(0)
  pausedAt                  DateTime?
  pausedMinutes             Int             @default(0)
  paymentNotes              String?
  paymentStatus             String?
  isRegularMaintenance      Boolean         @default(false)
  maintenanceFrequency      String?
  maintenanceFrequencyUnit  String?
  maintenanceFrequencyWeeks Int?
  preferredDay              String?
  preferredTimeBand         String?
  timePreferenceMode        String?
  visitPattern              String?
  archivedAt                DateTime?
  archivedByWorkerId        Int?
  cancelledAt               DateTime?
  cancelledByWorkerId       Int?
  cancellationReason        String?
  chasMessages              ChasMessage[]
  inboxMessages             InboxMessage[]
  customer                  Customer        @relation(fields: [customerId], references: [id])
  assignments               JobAssignment[]
  jobNotes                  JobNote[]
  photos                    JobPhoto[]
  auditLogs                 JobAuditLog[]
  notifications             Notification[]

  @@index([customerId])
  @@index([status, createdAt])
  @@index([visitDate, status])
  @@index([customerId, visitDate])
  @@index([jobType, visitDate])
  @@index([createdAt])
}

model JobAssignment {
  id        Int      @id @default(autoincrement())
  jobId     Int
  workerId  Int
  createdAt DateTime @default(now())
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([jobId, workerId])
  @@index([workerId, createdAt])
  @@index([jobId, createdAt])
}

model JobNote {
  id                Int      @id @default(autoincrement())
  jobId             Int
  note              String
  createdAt         DateTime @default(now())
  createdByWorkerId Int?
  worker            Worker?  @relation(fields: [createdByWorkerId], references: [id])
  job               Job      @relation(fields: [jobId], references: [id])

  @@index([jobId, createdAt])
  @@index([createdByWorkerId, createdAt])
}

model JobPhoto {
  id                 Int      @id @default(autoincrement())
  jobId              Int
  uploadedByWorkerId Int?
  label              String?
  imageUrl           String
  createdAt          DateTime @default(now())
  job                Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  uploadedByWorker   Worker?  @relation(fields: [uploadedByWorkerId], references: [id])

  @@index([jobId, createdAt])
  @@index([uploadedByWorkerId, createdAt])
}

model ChasMessage {
  id                   Int      @id @default(autoincrement())
  company              String
  worker               String
  workerId             Int?
  jobId                Int?
  question             String
  answer               String
  imageDataUrl         String?
  createdAt            DateTime @default(now())
  confidence           Float?
  conversationId       String?
  customerAddress      String?
  customerEmail        String?
  customerName         String?
  customerPhone        String?
  customerPostcode     String?
  enquiryReadyForKelly Boolean  @default(false)
  enquirySummary       String?
  escalateTo           String?
  estimatedHours       Float?
  intent               String?
  responseId           String?
  roughPriceText       String?
  safetyFlag           Boolean  @default(false)
  workSummary          String?
  sessionId            String?
  job                  Job?     @relation(fields: [jobId], references: [id])
  workerRecord         Worker?  @relation(fields: [workerId], references: [id])

  @@index([company, worker, createdAt])
  @@index([company, worker, sessionId, createdAt])
  @@index([jobId])
  @@index([workerId, createdAt])
  @@index([enquiryReadyForKelly, createdAt])
  @@index([conversationId])
}

model Conversation {
  id          String         @id @default(cuid())
  source      String
  contactName String?
  contactRef  String?
  archived    Boolean        @default(false)
  createdAt   DateTime       @default(now())
  messages    InboxMessage[]

  @@index([archived])
  @@index([source, createdAt])
}

model InboxMessage {
  id                Int      @id @default(autoincrement())
  source            String
  senderName        String?
  senderEmail       String?
  subject           String?
  preview           String?
  body              String?
  assignedTo        String?
  status            String   @default("unread")
  createdAt         DateTime @default(now())
  conversationId    String?
  customerId        Int?
  jobId             Int?
  senderPhone       String?
  externalMessageId String?
  conversation      Conversation? @relation(fields: [conversationId], references: [id])
  customer          Customer?     @relation(fields: [customerId], references: [id])
  job               Job?          @relation(fields: [jobId], references: [id])

  @@unique([source, externalMessageId])
  @@index([conversationId])
  @@index([source, createdAt])
  @@index([status, createdAt])
  @@index([customerId])
  @@index([jobId])
}

model InboxConnection {
  id                String   @id @default(cuid())
  service           String   @unique
  account           String?
  lastSync          DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  accessToken       String?
  externalAccountId String?
  refreshToken      String?
  syncError         String?
  tokenExpiresAt    DateTime?
}

model TimeOffRequest {
  id                Int      @id @default(autoincrement())
  workerId          Int
  requestType       String
  status            String   @default("pending")
  startDate         DateTime
  endDate           DateTime
  startTime         String?
  endTime           String?
  isFullDay         Boolean  @default(true)
  reason            String?
  requestedByName   String?
  reviewedByName    String?
  reviewNotes       String?
  reviewedAt        DateTime?
  cancelledAt       DateTime?
  cancellationNote  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  worker            Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  availabilityBlock WorkerAvailabilityBlock?

  @@index([workerId, status, startDate])
  @@index([status, createdAt])
  @@index([startDate, endDate])
}

model WorkerAvailabilityBlock {
  id        Int      @id @default(autoincrement())
  workerId  Int
  requestId Int?     @unique
  source    String   @default("time_off_request")
  title     String
  startDate DateTime
  endDate   DateTime
  startTime String?
  endTime   String?
  isFullDay Boolean  @default(true)
  notes     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  request   TimeOffRequest? @relation(fields: [requestId], references: [id])
  worker    Worker          @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId, active, startDate, endDate])
  @@index([startDate, endDate])
}

model JobAuditLog {
  id            Int      @id @default(autoincrement())
  jobId         Int
  actorWorkerId Int?
  action        String
  beforeJson    String?
  afterJson     String?
  createdAt     DateTime @default(now())
  job           Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  actorWorker   Worker?  @relation(fields: [actorWorkerId], references: [id])

  @@index([jobId, createdAt])
  @@index([actorWorkerId, createdAt])
  @@index([action, createdAt])
}

model Notification {
  id             Int      @id @default(autoincrement())
  jobId          Int
  kind           String
  channel        String   @default("sms")
  recipientPhone String
  scheduledFor   DateTime
  sentAt         DateTime?
  status         String   @default("pending")
  body           String?
  metaJson       String?
  failureReason  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([status, scheduledFor])
  @@index([kind, status, scheduledFor])
}